# ---- Supabase (public) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ---- Supabase (server only — never expose to the browser) ----
SUPABASE_SECRET_KEY=sb_secret_xxx

# ---- Database (for CLI migrations / scripts) ----
# Use the Session pooler URL (IPv4) from Supabase → Settings → Database
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ---- App encryption (AES-256-GCM) for LINE secrets at rest ----
APP_ENCRYPTION_KEY=  # 64 hex chars: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ---- LINE Messaging API (registered into line_accounts via scripts/register-line.mjs) ----
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_LIFF_ID=

# ---- OpenAI (Phase 4) ----
OPENAI_API_KEY=
